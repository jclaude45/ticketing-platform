# =============================================================================
# Ticketing Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file to version control!
# =============================================================================

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
POSTGRES_USER=ticketing
POSTGRES_PASSWORD=ticketing_secret
POSTGRES_DB=ticketing_db
DATABASE_URL=postgresql://ticketing:ticketing_secret@postgres:5432/ticketing_db

# =============================================================================
# Redis
# =============================================================================
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@redis:6379

# =============================================================================
# JWT Authentication
# =============================================================================
# Generate with: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# Email (SMTP)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@ticketing.com

# =============================================================================
# AWS S3 (File Storage)
# =============================================================================
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=ticketing-platform

# =============================================================================
# Application
# =============================================================================
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=TicketPlatform

# =============================================================================
# Domain (Production Only)
# =============================================================================
DOMAIN=yourdomain.com

# =============================================================================
# Two-Factor Authentication
# =============================================================================
TWO_FACTOR_AUTHENTICATION_APP_NAME=TicketPlatform

# =============================================================================
# Cryptography (RSA Keys for QR Signing)
# =============================================================================
CRYPTO_KEY_SIZE=4096
# RSA_PRIVATE_KEY and RSA_PUBLIC_KEY are loaded from files in /app/keys/
# Generate with: ./scripts/generate-keys.sh

# =============================================================================
# Rate Limiting
# =============================================================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# =============================================================================
# Nginx / SSL (Production)
# =============================================================================
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem
