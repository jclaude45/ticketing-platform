// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  ORGANIZER
  CONTROLLER
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum CampaignType {
  INVITATION
  CONFIRMATION
  REMINDER_7D
  REMINDER_1D
  CUSTOM
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PARTIALLY_SENT
  FAILED
}

enum RecipientStatus {
  PENDING
  SENT
  FAILED
}

enum TicketStatus {
  PENDING
  VALID
  USED
  CANCELLED
  FRAUDULENT
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum EventType {
  CONCERT
  CONFERENCE
  FESTIVAL
  SPORT
  PARTY
  EXHIBITION
  THEATER
  WORKSHOP
  OTHER
}

enum ScanResult {
  VALID
  ALREADY_USED
  INVALID
  FRAUDULENT
  EXPIRED
}

enum TeamMemberRole {
  MANAGER
  STAFF
  VOLUNTEER
  SECURITY
  PRESS
  VIP
  ARTIST
  SPONSOR
}

model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  password              String
  firstName             String
  lastName              String
  role                  Role      @default(ORGANIZER)
  isEmailVerified       Boolean   @default(false)
  emailVerificationToken String?
  emailVerificationExpiry DateTime?
  twoFactorSecret       String?
  twoFactorEnabled      Boolean   @default(false)
  passwordResetToken    String?
  passwordResetExpiry   DateTime?
  refreshToken          String?
  isActive              Boolean   @default(true)
  avatar                String?
  lastLoginAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  events       Event[]
  controllers  Controller[]
  keyPairs     KeyPair[]
  auditLogs    AuditLog[]
  subscription OrganizerSubscription?
  sentInvitations    ProjectInvitation[] @relation("SentInvitations")
  projectMemberships ProjectMember[]
  taskAssignments    TaskAssignee[]
  notificationTemplates NotificationTemplate[] @relation("UserTemplates")
  notificationCampaigns NotificationCampaign[] @relation("UserCampaigns")
  notifications         Notification[]
}

model Event {
  id               String      @id @default(uuid())
  name             String
  description      String?
  venue            String
  address          String?
  city             String
  country          String
  startDate        DateTime
  endDate          DateTime
  totalCapacity    Int
  status           EventStatus @default(DRAFT)
  type             EventType   @default(OTHER)
  bannerUrl        String?
  organizerId      String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  organizer         User               @relation(fields: [organizerId], references: [id])
  ticketTemplates   TicketTemplate[]
  tickets           Ticket[]
  controllerEvents  ControllerEvent[]
  teamMembers       TeamMember[]
  accreditations    Accreditation[]
  tasks             EventTask[]
  budgetLines       BudgetLine[]
  projectInvitations ProjectInvitation[]
  projectMembers     ProjectMember[]
  campaigns          NotificationCampaign[]
  payments           Payment[]
}

model TeamMember {
  id           String         @id @default(uuid())
  eventId      String
  name         String
  email        String?
  phone        String?
  role         TeamMemberRole @default(STAFF)
  department   String?
  notes        String?
  photoUrl     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  accreditation Accreditation?
}

model Accreditation {
  id           String    @id @default(uuid())
  teamMemberId String    @unique
  eventId      String
  code         String    @unique
  zones        Json      @default("[]")
  validFrom    DateTime?
  validUntil   DateTime?
  isActive     Boolean   @default(true)
  printedAt    DateTime?
  badgeConfig  Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  teamMember TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model TicketTemplate {
  id              String   @id @default(uuid())
  name            String
  description     String?
  price           Decimal  @db.Decimal(10, 2)
  currency        String   @default("USD")
  quantity        Int
  availableCount  Int
  color           String   @default("#1a1a2e")
  logoUrl         String?
  backgroundUrl   String?
  customFields    Json?
  eventId         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets Ticket[]
}

model Ticket {
  id               String       @id @default(uuid())
  serialNumber     String       @unique
  qrCode           String?      @db.Text
  qrCodeSignature  String?      @db.Text
  holderName       String?
  holderEmail      String?
  status           TicketStatus @default(PENDING)
  price            Decimal      @db.Decimal(10, 2)
  currency         String       @default("USD")
  purchasedAt      DateTime?
  checkedInAt      DateTime?
  cancelledAt      DateTime?
  metadata         Json?
  eventId          String
  templateId       String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  event           Event          @relation(fields: [eventId], references: [id])
  template        TicketTemplate @relation(fields: [templateId], references: [id])
  scanValidations ScanValidation[]
}

model Controller {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  isActive     Boolean  @default(true)
  organizerId  String
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organizer        User              @relation(fields: [organizerId], references: [id])
  controllerEvents ControllerEvent[]
  scanValidations  ScanValidation[]
}

model ControllerEvent {
  id           String   @id @default(uuid())
  controllerId String
  eventId      String
  assignedAt   DateTime @default(now())

  controller Controller @relation(fields: [controllerId], references: [id], onDelete: Cascade)
  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([controllerId, eventId])
}

model ScanValidation {
  id             String     @id @default(uuid())
  ticketId       String?    // nullable — null when QR code is invalid/unrecognized
  controllerId   String
  result         ScanResult
  scannedAt      DateTime   @default(now())
  deviceId       String?
  location       String?
  ipAddress      String?
  notes          String?
  isSynced       Boolean    @default(true)
  offlineScannedAt DateTime?

  ticket     Ticket?    @relation(fields: [ticketId], references: [id])
  controller Controller @relation(fields: [controllerId], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  entity      String?
  entityId    String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model KeyPair {
  id          String   @id @default(uuid())
  publicKey   String   @db.Text
  privateKey  String   @db.Text
  algorithm   String   @default("RSA-4096")
  isActive    Boolean  @default(true)
  organizerId String
  createdAt   DateTime @default(now())
  expiresAt   DateTime?

  organizer User @relation(fields: [organizerId], references: [id])
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

model SubscriptionPlan {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
  price           Float    @default(0)
  maxTickets      Int      @default(200)
  maxBadges       Int      @default(50)
  maxEvents       Int      @default(-1)
  showPoweredBy        Boolean  @default(true)
  allowBulkExport      Boolean  @default(true)
  allowCommunication   Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions OrganizerSubscription[]
}

model OrganizerSubscription {
  id          String             @id @default(uuid())
  organizerId String             @unique
  planId      String
  status      SubscriptionStatus @default(ACTIVE)
  ticketsUsed Int                @default(0)
  badgesUsed  Int                @default(0)
  startsAt    DateTime           @default(now())
  expiresAt   DateTime?
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  organizer User             @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
}

model EventTask {
  id           String    @id @default(uuid())
  eventId      String
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  status       String    @default("TODO")
  priority     String    @default("MEDIUM")
  category     String?
  assigneeName String?
  assigneeId   String?
  dueDate      DateTime?
  position     Int       @default(0)
  startDate    DateTime?
  assignees    TaskAssignee[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model BudgetLine {
  id            String          @id @default(uuid())
  eventId       String
  event         Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category      String
  label         String
  plannedAmount Float           @default(0)
  expenses      BudgetExpense[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model BudgetExpense {
  id           String     @id @default(uuid())
  budgetLineId String
  budgetLine   BudgetLine @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)
  label        String
  amount       Float
  date         DateTime   @default(now())
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model TaskAssignee {
  id        String    @id @default(uuid())
  taskId    String
  task      EventTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([taskId, userId])
}

model ProjectInvitation {
  id          String    @id @default(uuid())
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  email       String
  firstName   String
  lastName    String
  projectRole String    @default("CONTRIBUTOR")
  token       String    @unique
  status      String    @default("PENDING")
  invitedById String
  invitedBy   User      @relation("SentInvitations", fields: [invitedById], references: [id])
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ProjectMember {
  id          String   @id @default(uuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectRole String   @default("CONTRIBUTOR")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([eventId, userId])
}

model NotificationTemplate {
  id          String              @id @default(uuid())
  name        String
  channel     NotificationChannel
  subject     String?
  body        String              @db.Text
  isDefault   Boolean             @default(false)
  organizerId String
  organizer   User                @relation("UserTemplates", fields: [organizerId], references: [id], onDelete: Cascade)
  campaigns   NotificationCampaign[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model NotificationCampaign {
  id          String              @id @default(uuid())
  name        String
  eventId     String
  event       Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  channel     NotificationChannel
  type        CampaignType        @default(CUSTOM)
  subject     String?
  body        String              @db.Text
  templateId  String?
  template    NotificationTemplate? @relation(fields: [templateId], references: [id])
  scheduledAt DateTime?
  sentAt      DateTime?
  status      CampaignStatus      @default(DRAFT)
  totalSent   Int                 @default(0)
  totalFailed Int                 @default(0)
  createdById String
  createdBy   User                @relation("UserCampaigns", fields: [createdById], references: [id])
  recipients  CampaignRecipient[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model CampaignRecipient {
  id          String          @id @default(uuid())
  campaignId  String
  campaign    NotificationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  email       String?
  phone       String?
  firstName   String
  lastName    String
  ticketId    String?
  status      RecipientStatus @default(PENDING)
  sentAt      DateTime?
  error       String?
  createdAt   DateTime        @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Payment {
  id            String        @id @default(cuid())
  reference     String        @unique
  orderNumber   String?
  eventId       String
  holderName    String
  holderEmail   String
  holderPhone   String?
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("USD")
  paymentMethod String
  status        PaymentStatus @default(PENDING)
  items         Json
  providerRef   String?
  ticketsData   Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  event Event @relation(fields: [eventId], references: [id])

  @@index([reference])
  @@index([orderNumber])
  @@index([status])
}
